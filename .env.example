# ── Copy to .env and fill in ─────────────────────────────────────────────────

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///./financial_ocr.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/financial_ocr

# Model backend — "transformers" on CPU, "vllm" on GPU
MODEL_BACKEND=transformers

# vLLM server (only needed when MODEL_BACKEND=vllm)
VLLM_BASE_URL=http://localhost:8001/v1

# MLflow
MLFLOW_TRACKING_URI=mlruns

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
